---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "About Basile Roth — data analyst and researcher",
	title: "About",
};

const skills = [
	{
		category: "Data & Analyse",
		icon: "📊",
		items: ["Python", "pandas", "SQL", "R"],
	},
	{
		category: "Visualisation",
		icon: "🗺️",
		items: ["D3.js", "Leaflet", "Observable", "Datawrapper"],
	},
	{
		category: "Collecte de données",
		icon: "🔍",
		items: ["Scraping (BeautifulSoup, Selenium)", "APIs publiques", "data.gouv.fr"],
	},
	{
		category: "Journalisme",
		icon: "✍️",
		items: ["Fact-checking", "Enquête", "Datajournalisme", "Infographie"],
	},
];

// Placeholder — fill in with your actual timeline
const timeline = [
	{ year: "2025–présent", label: "Data journalist", detail: "Politis" },
	{ year: "2025", label: "Chargé de projet data", detail: "Data for Good" },
	{ year: "20XX–20XX", label: "Master · [Formation]", detail: "[École]" },
	{ year: "20XX–20XX", label: "Licence · [Formation]", detail: "[École]" },
];
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>

	<div class="prose prose-sm prose-cactus max-w-none mb-16">
		<p>
			Je suis data analyst et chercheur. Je travaille à l'intersection des données, de la politique
			et de l'environnement.
		</p>
		<p>
			Mes projets incluent des <a class="cactus-link" href="/work/">enquêtes journalistiques</a> pour Politis
			et des recherches sur les aires marines protégées en Antarctique.
		</p>
	</div>

	<!-- Timeline -->
	<section class="mb-16">
		<h2 class="title text-accent mb-8 text-xl">Parcours</h2>
		<div style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
		<div id="timeline-container" style="min-width: 760px; height: 300px;"></div>
	</div>
	</section>

	<!-- Skills -->
	<section class="mb-16">
		<h2 class="title text-accent mb-8 text-xl">Compétences</h2>
		<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
			{
				skills.map((block) => (
					<div class="border-muted rounded-lg border p-5">
						<p class="mb-3 font-semibold">
							<span class="me-2">{block.icon}</span>
							{block.category}
						</p>
						<ul class="flex flex-wrap gap-2" role="list">
							{block.items.map((skill) => (
								<li class="bg-accent/10 text-accent rounded px-2 py-0.5 text-xs font-medium">
									{skill}
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</section>
</PageLayout>

<script>
	import * as d3 from "https://cdn.jsdelivr.net/npm/d3@7/+esm";

	const timelineData = [
		{ year: "2014–2019", label: "Dipl. ingénieur big data", detail: "Formation", type: "edu" },
		{ year: "2019–2021", label: "M. Ing. Data Science", detail: "Formation", type: "edu" },
		{ year: "2020–2022", label: "Data scientist researcher", detail: "Nectar Technologies", type: "job" },
		{ year: "2022–2025", label: "Applied ML scientist", detail: "MILA", type: "job" },
		{ year: "2022–présent", label: "Animateur", detail: "Fresque du Climat", type: "benevole" },
		{ year: "2023–présent", label: "Data scientist bénévole", detail: "Data for Good", type: "benevole" },
		{ year: "2025–présent", label: "Freelance data", detail: "Indépendant", type: "job" },
	];

	const container = document.getElementById("timeline-container");
	if (!container) throw new Error("No container");

	const NODE_SPACING = 150;
	const margin = { top: 30, right: 120, bottom: 30, left: 120 };
	const height = 300;
	const n = timelineData.length;
	const innerW = NODE_SPACING * (n - 1);
	const width = innerW + margin.left + margin.right;

	container.style.width = width + "px";
	container.style.height = height + "px";

	const svg = d3
		.select(container)
		.append("svg")
		.attr("width", width)
		.attr("height", height);

	const g = svg.append("g").attr("transform", `translate(${margin.left},${margin.top})`);

	const spacing = NODE_SPACING;
	const cy = (height - margin.top - margin.bottom) / 2;

	// Detect dark mode
	const isDark = document.documentElement.dataset.theme === "dark";
	const lineColor = isDark ? "#6b7280" : "#d1d5db";
	const dotJob = "#2bbc8a";
	const dotEdu = "#d482ab";
	const dotBenevole = "#f59e0b";
	const textColor = isDark ? "#e5e7eb" : "#111827";
	const mutedColor = isDark ? "#9ca3af" : "#6b7280";

	// Horizontal axis line
	g.append("line")
		.attr("x1", 0)
		.attr("x2", innerW)
		.attr("y1", cy)
		.attr("y2", cy)
		.attr("stroke", lineColor)
		.attr("stroke-width", 2);

	const nodes = g
		.selectAll("g.node")
		.data(timelineData)
		.join("g")
		.attr("class", "node")
		.attr("transform", (_, i) => `translate(${i * spacing}, 0)`);

	// Alternating connector lines up/down
	nodes
		.append("line")
		.attr("x1", 0)
		.attr("x2", 0)
		.attr("y1", cy)
		.attr("y2", (_, i) => (i % 2 === 0 ? cy - 50 : cy + 50))
		.attr("stroke", lineColor)
		.attr("stroke-width", 1.5)
		.attr("stroke-dasharray", "4 3");

	// Dots
	nodes
		.append("circle")
		.attr("cx", 0)
		.attr("cy", cy)
		.attr("r", 7)
		.attr("fill", (d) => d.type === "job" ? dotJob : d.type === "edu" ? dotEdu : dotBenevole)
		.attr("stroke", "var(--color-global-bg)")
		.attr("stroke-width", 2);

	// Year label (below dot for even, above for odd)
	nodes
		.append("text")
		.attr("x", 0)
		.attr("y", (_, i) => (i % 2 === 0 ? cy + 22 : cy - 22))
		.attr("text-anchor", "middle")
		.attr("font-size", "10px")
		.attr("fill", mutedColor)
		.text((d) => d.year);

	// Role label
	nodes
		.append("text")
		.attr("x", 0)
		.attr("y", (_, i) => (i % 2 === 0 ? cy - 62 : cy + 62))
		.attr("text-anchor", "middle")
		.attr("font-size", "12px")
		.attr("font-weight", "600")
		.attr("fill", textColor)
		.text((d) => d.label);

	// Detail (org/school)
	nodes
		.append("text")
		.attr("x", 0)
		.attr("y", (_, i) => (i % 2 === 0 ? cy - 48 : cy + 76))
		.attr("text-anchor", "middle")
		.attr("font-size", "11px")
		.attr("fill", mutedColor)
		.text((d) => d.detail);

	// Legend
	const legend = svg
		.append("g")
		.attr("transform", `translate(${margin.left}, ${height - margin.bottom - 4})`);

	[
		{ color: dotJob, label: "Emploi" },
		{ color: dotEdu, label: "Formation" },
		{ color: dotBenevole, label: "Bénévolat" },
	].forEach(({ color, label }, i) => {
		const lg = legend.append("g").attr("transform", `translate(${i * 90}, 0)`);
		lg.append("circle").attr("r", 5).attr("cx", 5).attr("cy", 0).attr("fill", color);
		lg.append("text")
			.attr("x", 14)
			.attr("y", 4)
			.attr("font-size", "10px")
			.attr("fill", mutedColor)
			.text(label);
	});
</script>
