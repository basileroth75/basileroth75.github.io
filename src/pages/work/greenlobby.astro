---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "Greenlobby — Détail technique",
	description: "Détail technique du projet Greenlobby sur le lobbying en France.",
};
---

<PageLayout meta={meta}>
	<a class="text-muted hover:text-link mb-8 inline-flex items-center gap-1 text-sm" href="/work/">
		← Work
	</a>

	<h1 class="title mb-2 mt-6">Greenlobby — Comprendre et contrer le lobbying en France</h1>
	<p class="text-muted mb-2 text-sm">Juin 2025 · Data for Good × Greenlobby</p>
	<div class="mb-12 flex gap-4">
		<a
			class="cactus-link text-sm"
			href="https://website.services.dataforgood.fr/projets/green-lobby"
			rel="noreferrer noopener"
			target="_blank"
		>
			Voir le projet →
		</a>
		<a
			class="cactus-link text-sm"
			href="https://greenlobby.org/wp-content/uploads/2025/06/Infographie-Lobby-dinteret-general-Greenlobby.pdf"
			rel="noreferrer noopener"
			target="_blank"
		>
			Rapport PDF →
		</a>
	</div>

	<section class="mb-12">
		<h2 class="title text-accent mb-4 text-lg">Travail technique</h2>
		<div class="prose prose-sm prose-cactus max-w-none">
			<p><!-- Décris ici le travail technique réalisé : collecte de données, méthodologie, analyse... --></p>
		</div>
	</section>

	<section class="mb-12">
		<h2 class="title text-accent mb-4 text-lg">Technologies utilisées</h2>
		<ul class="flex flex-wrap gap-2">
			<!-- Ajoute ici les technologies utilisées -->
		</ul>
	</section>
</PageLayout>
