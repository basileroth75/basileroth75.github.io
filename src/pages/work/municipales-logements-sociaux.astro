---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "Municipales : quotas de logements sociaux — Détail technique",
	description: "Détail technique de la carte interactive sur le respect de la loi SRU.",
};
---

<PageLayout meta={meta}>
	<a class="text-muted hover:text-link mb-8 inline-flex items-center gap-1 text-sm" href="/work/">
		← Work
	</a>

	<h1 class="title mb-2 mt-6">Municipales : découvrez si votre commune respecte les quotas de logements sociaux</h1>
	<p class="text-muted mb-2 text-sm">12 février 2026 · Politis</p>
	<a
		class="cactus-link mb-12 inline-block text-sm"
		href="https://www.politis.fr/articles/2026/02/municipales-decouvrez-si-votre-commune-respecte-les-quotas-de-logements-sociaux/"
		rel="noreferrer noopener"
		target="_blank"
	>
		Lire l'article →
	</a>

	<section class="mb-12">
		<h2 class="title text-accent mb-4 text-lg">Travail technique</h2>
		<div class="prose prose-sm prose-cactus max-w-none">
			<p><!-- Décris ici le travail technique réalisé : collecte de données, méthodologie, analyse... --></p>
		</div>
	</section>

	<section class="mb-12">
		<h2 class="title text-accent mb-4 text-lg">Technologies utilisées</h2>
		<ul class="flex flex-wrap gap-2">
			<!-- Ajoute ici les technologies utilisées -->
		</ul>
	</section>
</PageLayout>
