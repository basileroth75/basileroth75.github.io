---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	title: "UNOC3 : couverture médiatique environnementale — Détail technique",
	description: "Détail technique de l'analyse de la couverture médiatique durant l'UNOC3.",
};
---

<PageLayout meta={meta}>
	<a class="text-muted hover:text-link mb-8 inline-flex items-center gap-1 text-sm" href="/work/">
		← Work
	</a>

	<h1 class="title mb-2 mt-6">L'UNOC3 rehausse la couverture médiatique des enjeux environnementaux à un niveau inédit depuis 2 ans</h1>
	<p class="text-muted mb-2 text-sm">17 juin 2025 · Observatoire des Médias sur l'Écologie (OMÉ) × Data for Good</p>
	<a
		class="cactus-link mb-12 inline-block text-sm"
		href="https://observatoiremediaecologie.fr/publication/lunoc3-rehausse-la-couverture-mediatique-des-enjeux-environnementaux-a-un-niveau-inedit-depuis-2-ans/"
		rel="noreferrer noopener"
		target="_blank"
	>
		Lire la publication →
	</a>

	<section class="mb-12">
		<h2 class="title text-accent mb-4 text-lg">Travail technique</h2>
		<div class="prose prose-sm prose-cactus max-w-none">
			<p><!-- Décris ici le travail technique réalisé : collecte de données, méthodologie, analyse... --></p>
		</div>
	</section>

	<section class="mb-12">
		<h2 class="title text-accent mb-4 text-lg">Technologies utilisées</h2>
		<ul class="flex flex-wrap gap-2">
			<!-- Ajoute ici les technologies utilisées -->
		</ul>
	</section>
</PageLayout>
