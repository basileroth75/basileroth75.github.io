---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "Contacter Basile Roth",
	title: "Contact",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">Contact</h1>

	<div class="prose prose-sm prose-cactus max-w-none mb-12">
		<p>
			N'hésitez pas à me contacter pour des collaborations, des projets data ou journalistiques, ou
			simplement pour échanger.
		</p>
	</div>

	<ul class="space-y-4 text-sm">
		<li class="flex items-center gap-3">
			<span class="text-muted w-20 shrink-0">Email</span>
			<a class="cactus-link" href="mailto:basile.roth@proton.me">basile.roth@proton.me</a>
		</li>
		<li class="flex items-center gap-3">
			<span class="text-muted w-20 shrink-0">GitHub</span>
			<a
				class="cactus-link"
				href="https://github.com/basileroth75"
				rel="noreferrer noopener"
				target="_blank"
			>
				basileroth75
			</a>
		</li>
		<li class="flex items-center gap-3">
			<span class="text-muted w-20 shrink-0">Signal</span>
			<a
				class="cactus-link"
				href="https://signal.me/#eu/jTM6MausYd8XNgJ86agbIgBspeQK9K4KeGjVwCmsqioqmQ8yB2lNfrbVF4CR-Fnd"
				rel="noreferrer noopener"
				target="_blank"
			>
				Me contacter sur Signal
			</a>
		</li>
		<li class="flex items-center gap-3">
			<span class="text-muted w-20 shrink-0">LinkedIn</span>
			<a
				class="cactus-link"
				href="https://www.linkedin.com/in/basileroth/"
				rel="noreferrer noopener"
				target="_blank"
			>
				basileroth
			</a>
		</li>
	</ul>
</PageLayout>
