---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "CV de Basile Roth — Senior Data Scientist",
	title: "CV & Intérêts",
};

const interests = [
	{
		title: "Sports d'endurance",
		icon: "🏃",
		description:
			"Finisher du Norseman — le championnat mondial d'extrême triathlon en Norvège. Sur plusieurs années, j'ai longuement étudié la littérature scientifique sur la physiologie, l'entrainement J'ai aussi couru de multiples ultra-trails et marathons.",
		tags: ["Endurance", "Physiologie", "Analyse"],
		link: { href: "https://podcasts.apple.com/fr/podcast/ep07-%C3%A0-l%C3%A9preuve-des-fjords-le-norseman/id1697355203?i=1000643078559", label: "Podcast : À l'épreuve des fjords →" },
	},
	{
		title: "Rugby",
		icon: "🏉",
		description:
			"Depuis tout jeune passionné de sports collectifs et plus particulièrement de rugby. Je le pratique encore sur mon temps libre et j'ai eu l'opportunité de jouer en tant qu'étudiant athlète au plus haut niveau en Amérique du Nord. Le rugby m'a appris l'importance du collectif. Éducateur des équipes jeunes au sein de mon club formateur en région parisienne.",
		tags: ["Équipe","Cohésion"],
	},
	{
		title: "Lecture, Presse & Culture",
		icon: "📚",
		description:
			"Passionné de non-fiction : sciences, politique, histoire et essais. Lecteur régulier de la presse indépendante et engagée. Expériences professionnelles et personnelles au Canada, en Australie et en Afrique du Sud et dans une vaste partie de l'Amérique du Sud — citoyen français, australien et suisse.",
		tags: ["Presse", "International","Écriture"],
	},
	{
		title: "Travail manuel et réparation",
		icon: "🔧",
		description:
			"Passionné par la réparation et la création — réparation de vélos, couture, et diverses pratiques de bricolage. J'aime construire et réparer avec mes mains pour me détendre.",
		tags: ["Vélo", "Réparation","Couture"],
	},
];
---

<PageLayout meta={meta}>
	<div class="mb-8 flex items-center justify-between gap-4">
		<h1 class="title">CV</h1>
		<a
			class="border-muted hover:border-accent hover:text-accent rounded border px-4 py-2 text-sm font-medium transition-colors"
			href="/CV_Basile_Roth.pdf"
			download
		>
			Télécharger (PDF)
		</a>
	</div>

	<!-- PDF preview -->
	<div class="mb-16">
		<div id="pdf-container" class="border-muted rounded-lg border overflow-hidden bg-[#f4f4f4] dark:bg-[#1a1a1a]">
			<div id="pdf-pages" class="flex flex-col items-center gap-4 p-4"></div>
			<div id="pdf-error" class="hidden flex-col items-center justify-center gap-4 p-12 text-center">
				<p class="text-muted text-sm">Impossible d'afficher le PDF.</p>
				<a
					class="border-muted hover:border-accent hover:text-accent rounded border px-4 py-2 text-sm font-medium transition-colors"
					href="//CV_Basile_Roth.pdf"
					target="_blank"
				>
					Ouvrir le PDF →
				</a>
			</div>
		</div>
	</div>

	<!-- Interests section -->
	<div class="mt-16">
		<h2 class="title mb-4">Intérêts</h2>
		<p class="text-muted mb-16 text-sm">Ce qui m'anime en dehors du travail.</p>

		<ul class="grid gap-5 sm:grid-cols-2" role="list">
			{
				interests.map((item, i) => (
					<li class={`border-muted flex flex-col rounded-lg border p-5${i === interests.length - 1 && interests.length % 2 !== 0 ? " sm:col-span-2" : ""}`}>
						<p class="mb-3 text-2xl">{item.icon}</p>
						<p class="mb-2 font-semibold">{item.title}</p>
						<p class="text-muted flex-1 text-sm">{item.description}</p>
						<div class="mt-4 flex flex-wrap gap-1.5">
							{item.tags.map((tag) => (
								<span class="bg-accent/10 text-accent rounded px-2 py-0.5 text-xs font-medium">
									{tag}
								</span>
							))}
						</div>
						{item.link && (
							<a
								href={item.link.href}
								target="_blank"
								rel="noreferrer noopener"
								class="cactus-link mt-4 text-xs"
							>
								{item.link.label}
							</a>
						)}
					</li>
				))
			}
		</ul>
	</div>

	<script>
		async function renderPDF() {
			try {
				// @ts-ignore
				const pdfjsLib = await import("https://cdn.jsdelivr.net/npm/pdfjs-dist@4.9.155/build/pdf.min.mjs");
				pdfjsLib.GlobalWorkerOptions.workerSrc =
					"https://cdn.jsdelivr.net/npm/pdfjs-dist@4.9.155/build/pdf.worker.min.mjs";

				const pdf = await pdfjsLib.getDocument("/CV_Basile_Roth.pdf").promise;
				const container = document.getElementById("pdf-pages")!;

				for (let i = 1; i <= pdf.numPages; i++) {
					const page = await pdf.getPage(i);
					const containerWidth = container.clientWidth - 32;
					const viewport = page.getViewport({ scale: 1 });
					const scale = containerWidth / viewport.width;
					const scaled = page.getViewport({ scale });

					const canvas = document.createElement("canvas");
					canvas.width = scaled.width;
					canvas.height = scaled.height;
					canvas.style.width = "100%";
					canvas.style.maxWidth = scaled.width + "px";
					canvas.style.borderRadius = "4px";
					canvas.style.boxShadow = "0 2px 8px rgba(0,0,0,0.15)";

					container.appendChild(canvas);

					await page.render({
						canvasContext: canvas.getContext("2d")!,
						viewport: scaled,
					}).promise;
				}
			} catch (e) {
				document.getElementById("pdf-pages")!.classList.add("hidden");
				document.getElementById("pdf-error")!.classList.remove("hidden");
				document.getElementById("pdf-error")!.classList.add("flex");
			}
		}

		renderPDF();
	</script>

</PageLayout>
